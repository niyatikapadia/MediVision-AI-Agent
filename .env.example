# MediVision AI Agent — Environment Variables
# Copy this file to .env and fill in your values

# LLM API keys (only needed for cloud backends)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model paths
SEGMENTATION_MODEL_PATH=models/unet_resnet34_multiorgan.pth

# RAG settings
PUBMED_API_KEY=your_pubmed_api_key_here   # optional — for live PubMed access
RAG_TOP_K=5

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
